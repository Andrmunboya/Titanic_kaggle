import pandas as pd
from sklearn.tree import DecisionTreeClassifier, plot_tree
import matplotlib.pyplot as plt

# 1. Читаем файл train.csv, который ты загрузил вручную
import pandas as pd
data = pd.read_csv('train.csv')

# 2. Выбираем нужные колонки и очищаем данные
data = data[['Pclass', 'Sex', 'Age', 'Survived']].dropna()

# Превращаем пол в числа: male -> 1, female -> 0
data['Sex'] = data['Sex'].map({'male': 1, 'female': 0})

X = data[['Pclass', 'Sex', 'Age']]
y = data['Survived']


# 3. Создаем модель дерева решений.
# Используем критерий энтропии и ограничиваем глубину до 3 уровней, чтобы дерево было читаемым
model = DecisionTreeClassifier(criterion='entropy', max_depth=3, random_state=42)

# 4. ЗАПУСКАЕМ ОБУЧЕНИЕ! Модель прямо сейчас считает энтропию тысячи раз
model.fit(X, y)

# 5. ВИЗУАЛИЗАЦИЯ: Просим модель показать дерево, которое она построила САМА
plt.figure(figsize=(15, 10))
plot_tree(model, feature_names=X.columns, class_names=['Погиб', 'Выжил'], filled=True, rounded=True)
plt.show()

# 6. ТЕСТИРУЕМ: Пассажир: 3 класс, мужчина (1), 22 года
new_passenger = [[3, 1, 22]]
prediction = model.predict(new_passenger)
probability = model.predict_proba(new_passenger)

print("\n--- РЕЗУЛЬТАТ РАБОТЫ ВАШЕЙ МОДЕЛИ ---")
if prediction[0] == 1:
    print(f"Модель предсказывает: Пассажир ВЫЖИЛ! (Уверенность: {probability[0][1]*100:.1f}%)")
else:
    print(f"Модель предсказывает: Пассажир ПОГИБ. (Уверенность: {probability[0][0]*100:.1f}%)")

